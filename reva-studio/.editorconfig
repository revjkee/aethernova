root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

[*.pyi]
indent_style = space
indent_size = 4
max_line_length = 88

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 4

[*.ini]
indent_style = space
indent_size = 4

[*.cfg]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.rst]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[*.txt]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 4

[Dockerfile]
indent_style = space
indent_size = 4

[*.dockerfile]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.scss]
indent_style = space
indent_size = 2

[*.html]
indent_style = space
indent_size = 2

[*.sql]
indent_style = space
indent_size = 4

[alembic.ini]
indent_style = space
indent_size = 4

[.env]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[.env.*]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
end_of_line = crlf
indent_style = space
indent_size = 4

[*.{png,jpg,jpeg,gif,svg,ico,webp,pdf}]
insert_final_newline = false
trim_trailing_whitespace = false