# =========================================================
# Reva Studio
# Industrial .gitignore
# Stack: Python, FastAPI, aiogram, Alembic, Docker, tests,
# optional frontend, IDEs, local secrets, build artifacts
# =========================================================

# ---------------------------------------------------------
# OS / Filesystem noise
# ---------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/
._*

# ---------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------
.idea/
.vscode/
.vscode-test/
*.code-workspace

# JetBrains
*.iml
out/

# Vim / Emacs / temporary editor files
*~
*.swp
*.swo
\#*\#
*.tmp
*.bak

# ---------------------------------------------------------
# Python bytecode / cache
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo

# ---------------------------------------------------------
# Python virtual environments
# ---------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------
# Python tooling caches
# ---------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.nox/
.tox/
.dmypy.json
coverage.xml
.coverage
.coverage.*
htmlcov/

# ---------------------------------------------------------
# Packaging / build artifacts
# ---------------------------------------------------------
build/
dist/
site/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/
wheels/

# ---------------------------------------------------------
# Installer / logs
# ---------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt
*.log
logs/
log/
*.pid
*.seed
*.out
*.err

# ---------------------------------------------------------
# Test / profiling / debug artifacts
# ---------------------------------------------------------
.cache/
pytestdebug.log
*.cover
*.py,cover
.prof
*.prof
*.lprof
*.dmp

# ---------------------------------------------------------
# Jupyter / notebooks
# ---------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------
# Local environment / secrets
# Never commit real credentials
# ---------------------------------------------------------
.env
.env.*
!.env.example
!.env.test.example
!.env.dev.example
!.env.prod.example

*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.der
*.kdbx
secrets/
secret/
private/
private_keys/
keys/
certs/*.key
certs/*.pem

# ---------------------------------------------------------
# SQLite / local databases / dumps
# ---------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
*.sql
*.dump

# ---------------------------------------------------------
# Application runtime data
# ---------------------------------------------------------
tmp/
temp/
run/
runtime/
uploads/
media/
staticfiles/
public/uploads/

# ---------------------------------------------------------
# FastAPI / Uvicorn / Gunicorn
# ---------------------------------------------------------
gunicorn.conf.pyc
uvicorn*.log

# ---------------------------------------------------------
# Alembic / migrations generated noise
# Keep migration source files in repo, ignore compiled/cache
# ---------------------------------------------------------
migrations/**/__pycache__/
alembic/**/__pycache__/
*.pyc

# ---------------------------------------------------------
# Pydantic / generated schema exports / local snapshots
# ---------------------------------------------------------
schemas/generated/
openapi.json
openapi.yaml

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------
docker-data/
docker-volumes/
*.tar
*.tar.gz

# Docker override files that may contain local-only config
docker-compose.override.yml
docker-compose.local.yml

# ---------------------------------------------------------
# Kubernetes / Helm local rendered output
# ---------------------------------------------------------
.manifests/
.rendered/
helmfile.lock
*.dec.yaml

# ---------------------------------------------------------
# Observability / monitoring local state
# ---------------------------------------------------------
.prometheus/
grafana-data/
loki-data/
tempo-data/
promtail-data/
alertmanager-data/

# ---------------------------------------------------------
# Redis / Celery / broker local files
# ---------------------------------------------------------
celerybeat-schedule
celerybeat.pid
redis-data/
rabbitmq-data/

# ---------------------------------------------------------
# Frontend / Node / JS / TS
# Keep this because project can grow into fullstack
# ---------------------------------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
storybook-static/
dist-ssr/
coverage/
*.tsbuildinfo

# Frontend env files
frontend/.env
frontend/.env.*
!frontend/.env.example

# ---------------------------------------------------------
# Frontend build / framework artifacts
# ---------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.next/
frontend/.nuxt/
frontend/.cache/
frontend/coverage/

# ---------------------------------------------------------
# Static analysis / security / audit outputs
# ---------------------------------------------------------
bandit-report.json
safety-report.json
pip-audit-report.json
semgrep-report.json
trivy-report.json
grype-report.json
dependency-check-report/
reports/
artifacts/

# ---------------------------------------------------------
# Documentation generated files
# ---------------------------------------------------------
docs/_build/
docs/site/
mkdocs-site/

# ---------------------------------------------------------
# Local backups / archives
# ---------------------------------------------------------
backup/
backups/
*.zip
*.7z
*.rar
*.gz
*.bz2

# ---------------------------------------------------------
# Terraform / infra local state
# In case infra is added later
# ---------------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---------------------------------------------------------
# Ansible local / vault temp
# ---------------------------------------------------------
*.retry
.vault_pass.txt

# ---------------------------------------------------------
# Generated images / binary assets not meant for git
# Uncomment if needed
# ---------------------------------------------------------
# *.png
# *.jpg
# *.jpeg
# *.webp
# *.pdf

# ---------------------------------------------------------
# Keep important empty dirs if placeholders are used
# ---------------------------------------------------------
!.gitkeep
!.keep