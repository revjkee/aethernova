# --------------------------------------------------
# VCS
# --------------------------------------------------
.git
.gitignore
.gitattributes

# --------------------------------------------------
# Python bytecode / cache
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# --------------------------------------------------
# Python tooling cache
# --------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.tox/
.nox/
.dmypy.json

# --------------------------------------------------
# Coverage / test artifacts
# --------------------------------------------------
.coverage
.coverage.*
coverage/
coverage.xml
htmlcov/
junit.xml
test-results/
reports/
pytestdebug.log

# --------------------------------------------------
# Virtual environments
# --------------------------------------------------
.venv/
venv/
env/
ENV/

# --------------------------------------------------
# Build / packaging artifacts
# --------------------------------------------------
build/
dist/
site/
pip-wheel-metadata/
*.egg-info/
.eggs/
wheels/

# --------------------------------------------------
# Local runtime artifacts
# --------------------------------------------------
*.log
logs/
log/
tmp/
temp/
*.tmp
*.pid
*.seed
*.out
*.err
*.stackdump

# --------------------------------------------------
# Environment / secrets
# Keep examples in repo, exclude real local env files
# --------------------------------------------------
.env
.env.*
!.env.example
!.env.test.example
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx

# --------------------------------------------------
# Editors / IDE
# --------------------------------------------------
.vscode/
.idea/
*.iml
*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*.swo
*~

# --------------------------------------------------
# OS / file manager junk
# --------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# --------------------------------------------------
# Node / frontend artifacts
# Useful if frontend tooling appears in mono-repo later
# --------------------------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn-cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
coverage-final.json

# --------------------------------------------------
# Docker / local compose overrides / runtime volumes
# Do not exclude actual Dockerfiles or canonical compose files
# --------------------------------------------------
docker-data/
volumes/
*.local.yml
docker-compose.override.yml

# --------------------------------------------------
# Documentation generated artifacts
# --------------------------------------------------
docs/_build/
docs/build/

# --------------------------------------------------
# Notebook / data science noise
# --------------------------------------------------
.ipynb_checkpoints/

# --------------------------------------------------
# Local databases / binary artifacts
# --------------------------------------------------
*.sqlite
*.sqlite3
*.db

# --------------------------------------------------
# Project-specific temporary folders
# --------------------------------------------------
.artifacts/
.cache/