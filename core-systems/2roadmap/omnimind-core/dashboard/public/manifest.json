{
  "id": "/omnimind-dashboard",
  "name": "OmniMind Dashboard",
  "short_name": "OmniMind",
  "description": "Промышленная PWA-панель управления ядром OmniMind: мониторинг, алерты, оркестрация и аналитика.",
  "lang": "ru-RU",
  "dir": "ltr",

  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "orientation": "any",
  "theme_color": "#0F172A",
  "background_color": "#0B1221",
  "categories": ["business", "productivity", "utilities", "developer-tools", "monitoring"],

  "icons": [
    { "src": "/icons/icon-192.png",           "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192-maskable.png",  "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-256.png",           "sizes": "256x256", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-256-maskable.png",  "sizes": "256x256", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-384.png",           "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-384-maskable.png",  "sizes": "384x384", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-512.png",           "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512-maskable.png",  "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-monochrome.svg",    "sizes": "any",     "type": "image/svg+xml", "purpose": "monochrome" }
  ],

  "screenshots": [
    { "src": "/screenshots/dashboard-wide.png",  "sizes": "1920x1080", "type": "image/png", "form_factor": "wide",   "label": "Главная панель (десктоп)" },
    { "src": "/screenshots/alerts-narrow.png",   "sizes": "540x1120",  "type": "image/png", "form_factor": "narrow", "label": "Алерты и события (мобильный)" }
  ],

  "shortcuts": [
    {
      "name": "Мониторинг",
      "short_name": "Мониторинг",
      "description": "Открыть дашборд метрик",
      "url": "/monitoring",
      "icons": [{ "src": "/icons/shortcut-monitoring.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Инциденты",
      "short_name": "Инциденты",
      "description": "Лента инцидентов и алертов",
      "url": "/incidents",
      "icons": [{ "src": "/icons/shortcut-incidents.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Настройки",
      "short_name": "Настройки",
      "description": "Параметры и интеграции",
      "url": "/settings",
      "icons": [{ "src": "/icons/shortcut-settings.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],

  "protocol_handlers": [
    { "protocol": "web+omnimind", "url": "/open?url=%s" }
  ],

  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["text/*", "image/*", "application/json", "application/zip", "application/pdf"]
        }
      ]
    }
  },

  "launch_handler": { "client_mode": "focus-existing" },
  "capture_links": "existing-client-navigate",
  "prefer_related_applications": false
}
