    "fairness_metrics": {
      "file": "src/fairness_metrics.py",
      "loc": 520,
      "status": "complete",
      "metrics": [
        {
          "name": "Demographic Parity",
          "formula": "P(Y_hat=1|A=0) ≈ P(Y_hat=1|A=1)",
          "threshold": "difference < 0.1"
        },
        {
          "name": "Equal Opportunity",
          "formula": "P(Y_hat=1|Y=1,A=0) ≈ P(Y_hat=1|Y=1,A=1)",
          "threshold": "difference < 0.1"
        },
        {
          "name": "Equalized Odds",
          "formula": "Equal TPR and FPR across groups",
          "threshold": "both differences < 0.1"
        },
        {
          "name": "Disparate Impact",
          "formula": "P(Y_hat=1|A=1) / P(Y_hat=1|A=0) >= 0.8",
          "threshold": "ratio >= 0.8 (80% rule)"
        }
      ],
      "fairness_threshold": 0.8,
      "report_generation": true
    },
