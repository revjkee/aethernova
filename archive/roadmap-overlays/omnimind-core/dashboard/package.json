{
  "name": "@aethernova/omnimind-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "OmniMind Core — industrial React + Vite dashboard (Feature-Sliced, Storybook, OTEL, CI/CD ready)",
  "repository": {
    "type": "git",
    "url": "git@github.com:ORG/REPO.git"
  },
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=8"
  },
  "license": "MIT",
  "homepage": "https://dashboard.omnimind.example.com",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build --sourcemap",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --ext .ts,.tsx src --max-warnings=0",
    "lint:fix": "eslint --ext .ts,.tsx src --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "vitest run",
    "test:ui": "vitest",
    "e2e": "playwright test",
    "storybook": "storybook dev -p 6006 -s public",
    "build:storybook": "build-storybook -o storybook-static",
    "visual:ci": "npx @playwright/test --config=playwright.config.ts --reporter=list",
    "analyze": "pnpm build && node ./scripts/visualize-bundle.js",
    "clean": "rimraf dist .turbo node_modules .cache",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm build:storybook",
    "prepublishOnly": "pnpm build",
    "prepare": "husky install",
    "release": "semantic-release",
    "snyk:monitor": "snyk monitor",
    "docker:build": "docker build -t omnimind-dashboard:${CI_COMMIT_TAG:-canary} -f Dockerfile .",
    "helm:package": "helm package helm/omnimind-dashboard --destination ./dist/helm"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.1",
    "@tanstack/react-query": "^5.3.0",
    "axios": "^1.5.0",
    "zustand": "^4.4.0",
    "clsx": "^1.2.1",
    "date-fns": "^2.30.0",
    "chart.js": "^4.4.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "i18next": "^23.0.0",
    "react-i18next": "^13.0.0",
    "tailwindcss": "^3.5.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "nanoid": "^4.0.0",
    "resize-observer-polyfill": "^1.5.1",
    "sentry-browser": "^7.0.0",
    "jwt-decode": "^3.1.2",
    "whatwg-fetch": "^3.6.2",
    "styled-components": "^6.0.0",
    "@aethernova/ui": "workspace:*",
    "@aethernova/api-client": "workspace:*",
    "@aethernova/telemetry": "workspace:*",
    "@aethernova/microfrontend-runtime": "workspace:*"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "typescript": "^5.5.0",
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.11",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.11.2",
    "prettier": "^3.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "commitlint": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "vitest": "^1.5.8",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^22.1.0",
    "playwright": "^1.40.0",
    "@playwright/test": "^1.40.0",
    "@storybook/react": "^7.0.0",
    "@storybook/addon-essentials": "^7.0.0",
    "chromatic": "^7.0.0",
    "stylelint": "^15.0.0",
    "stylelint-config-recommended-scss": "^6.0.0",
    "source-map-explorer": "^2.6.2",
    "rollup-plugin-visualizer": "^5.10.1",
    "rimraf": "^5.0.0",
    "semantic-release": "^21.0.0",
    "snyk": "^1.1000.0",
    "openapi-typescript-codegen": "^0.22.0",
    "concurrently": "^8.0.0",
    "depcheck": "^1.5.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@aethernova/ui",
        "@aethernova/api-client",
        "@aethernova/telemetry"
      ]
    }
  },
  "files": [
    "dist",
    "storybook-static",
    "helm"
  ],
  "sideEffects": false,
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "edge >= 18"
  ],
  "keywords": [
    "omnimind",
    "dashboard",
    "observability",
    "aethernova",
    "react",
    "vite",
    "microfrontend"
  ],
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
