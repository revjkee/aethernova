{
  "name": "AetherNova Dev",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "backend",
  "workspaceFolder": "/workspaces/aethernova",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/aethernova,type=bind",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "remoteEnv": {
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  },
  "postCreateCommand": "python -m pip install -r requirements-dev.txt && npm --prefix frontend ci",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },
  "portsAttributes": {
    "5173": { "label": "Vite", "onAutoForward": "openBrowser" },
    "8000": { "label": "API", "onAutoForward": "openBrowser" },
    "3030": { "label": "Signal WS" }
  }
}
