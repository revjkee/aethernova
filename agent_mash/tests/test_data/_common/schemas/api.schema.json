{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-mash.local/schemas/api.base.schema.json",
  "title": "BaseApiResponse",
  "description": "Common base schema for all API responses used in agent_mash tests",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "meta"
  ],
  "properties": {
    "status": {
      "type": "string",
      "description": "High level response status",
      "enum": [
        "success",
        "error",
        "warning"
      ]
    },
    "result": {
      "description": "Payload for success or warning responses",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "error": {
      "description": "Error details for failed responses",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "type",
        "code",
        "message"
      ],
      "properties": {
        "type": {
          "type": "string",
          "description": "Error category"
        },
        "code": {
          "type": "string",
          "description": "Machine readable error code"
        },
        "message": {
          "type": "string",
          "description": "Human readable error description"
        },
        "details": {
          "type": "array",
          "description": "Optional list of error details",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "field",
              "issue"
            ],
            "properties": {
              "field": {
                "type": "string"
              },
              "issue": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Response metadata",
      "additionalProperties": false,
      "required": [
        "http_status",
        "request_id",
        "timestamp"
      ],
      "properties": {
        "http_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp"
        },
        "processing_mode": {
          "type": "string",
          "description": "Optional processing mode indicator",
          "enum": [
            "normal",
            "degraded"
          ]
        }
      }
    }
  },
  "oneOf": [
    {
      "required": [
        "status",
        "result",
        "meta"
      ],
      "properties": {
        "status": {
          "const": "success"
        },
        "error": {
          "type": "null"
        }
      }
    },
    {
      "required": [
        "status",
        "error",
        "meta"
      ],
      "properties": {
        "status": {
          "const": "error"
        },
        "result": {
          "type": "null"
        }
      }
    },
    {
      "required": [
        "status",
        "result",
        "meta"
      ],
      "properties": {
        "status": {
          "const": "warning"
        }
      }
    }
  ]
}
