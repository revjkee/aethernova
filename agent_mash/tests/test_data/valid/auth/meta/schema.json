{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-mash.local/schemas/auth/login-valid.schema.json",
  "title": "ValidLoginRequest",
  "description": "Schema for valid authentication login request used in automated tests",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "username",
    "password",
    "grant_type",
    "client_id"
  ],
  "properties": {
    "username": {
      "type": "string",
      "description": "Synthetic user identifier used for authentication tests",
      "minLength": 3,
      "maxLength": 255,
      "format": "email"
    },
    "password": {
      "type": "string",
      "description": "Synthetic password used only in test environments",
      "minLength": 8,
      "maxLength": 128
    },
    "grant_type": {
      "type": "string",
      "description": "Authentication grant type",
      "enum": [
        "password"
      ]
    },
    "client_id": {
      "type": "string",
      "description": "Identifier of the test client application",
      "minLength": 3,
      "maxLength": 64
    },
    "remember_me": {
      "type": "boolean",
      "description": "Optional flag indicating persistent session",
      "default": false
    },
    "meta": {
      "type": "object",
      "description": "Test metadata, not used by authentication logic",
      "additionalProperties": false,
      "required": [
        "source",
        "scenario",
        "variant"
      ],
      "properties": {
        "source": {
          "type": "string",
          "description": "Origin of the test data",
          "enum": [
            "automated_tests"
          ]
        },
        "scenario": {
          "type": "string",
          "description": "Authentication scenario name",
          "enum": [
            "login_valid"
          ]
        },
        "variant": {
          "type": "string",
          "description": "Scenario variant identifier",
          "pattern": "^[0-9]{2}$"
        }
      }
    }
  }
}
