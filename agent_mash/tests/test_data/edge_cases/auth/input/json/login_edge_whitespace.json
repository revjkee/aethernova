{
  "description": "Authentication edge cases related to whitespace handling in login and password fields",
  "cases": [
    {
      "id": "login_leading_trailing_spaces",
      "input": {
        "login": "  user@example.com  ",
        "password": "CorrectHorseBatteryStaple!"
      },
      "expected": {
        "should_authenticate": true,
        "normalized_login": "user@example.com"
      }
    },
    {
      "id": "login_only_whitespace",
      "input": {
        "login": "     ",
        "password": "CorrectHorseBatteryStaple!"
      },
      "expected": {
        "should_authenticate": false,
        "error": "login_empty_after_trim"
      }
    },
    {
      "id": "login_internal_whitespace",
      "input": {
        "login": "user @example.com",
        "password": "CorrectHorseBatteryStaple!"
      },
      "expected": {
        "should_authenticate": false,
        "error": "login_invalid_format"
      }
    },
    {
      "id": "password_leading_trailing_spaces",
      "input": {
        "login": "user@example.com",
        "password": "  CorrectHorseBatteryStaple!  "
      },
      "expected": {
        "should_authenticate": false,
        "error": "password_mismatch"
      }
    },
    {
      "id": "login_with_tabs_and_newlines",
      "input": {
        "login": "\n\tuser@example.com\t\n",
        "password": "CorrectHorseBatteryStaple!"
      },
      "expected": {
        "should_authenticate": true,
        "normalized_login": "user@example.com"
      }
    }
  ]
}
