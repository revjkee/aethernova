{
  "meta": {
    "case_id": "auth.login.edge.expected.001",
    "title": "Expected response for login edge-case scenarios",
    "description": "Defines acceptable API behavior for authentication edge cases such as unicode input, excessive length, or whitespace normalization.",
    "domain": "auth",
    "operation": "login",
    "category": "edge_case",
    "stability": "stable",
    "version": "1.0"
  },
  "response_contract": {
    "http_status_any_of": [
      200,
      400,
      401,
      422
    ],
    "content_type_must_be": [
      "application/json"
    ]
  },
  "error_semantics": {
    "when_error": {
      "must_not_disclose": [
        "internal_state",
        "stack_trace",
        "exception",
        "sql",
        "password_hash"
      ],
      "message_characteristics": {
        "language": "neutral",
        "contains_any_of": [
          "invalid",
          "credentials",
          "validation",
          "format",
          "login"
        ],
        "must_not_contain": [
          "panic",
          "traceback",
          "segmentation fault"
        ]
      }
    }
  },
  "success_semantics": {
    "when_success": {
      "token_presence_any_of": [
        "access_token",
        "token",
        "jwt"
      ],
      "token_constraints": {
        "type": "string",
        "min_length": 16
      }
    }
  },
  "security_expectations": {
    "rate_limit_headers_optional": true,
    "timing_attack_mitigation_expected": true,
    "error_uniformity_expected": true
  },
  "invariants": {
    "response_must_be_json_object": true,
    "no_sensitive_fields_exposed": true,
    "schema_backward_compatible": true
  }
}
