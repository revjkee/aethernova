{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aethernova.local/schemas/tests/auth/invalid/meta.schema.json",
  "title": "Invalid Auth Test Meta Schema",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "id",
    "suite",
    "domain",
    "case_type",
    "description",
    "created_at",
    "expected"
  ],

  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable identifier for the test case (lowercase, deterministic)."
    },

    "suite": {
      "type": "string",
      "const": "auth",
      "description": "Top-level suite name."
    },

    "domain": {
      "type": "string",
      "const": "invalid",
      "description": "Dataset domain marker: invalid data."
    },

    "case_type": {
      "type": "string",
      "enum": [
        "missing_field",
        "invalid_type",
        "invalid_format",
        "constraint_violation",
        "tampered_payload",
        "replay",
        "expired",
        "unauthorized",
        "forbidden",
        "rate_limited",
        "signature_invalid"
      ],
      "description": "Category of invalid auth scenario."
    },

    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Human-readable explanation of the scenario."
    },

    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp when the case was authored."
    },

    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "minItems": 0,
      "maxItems": 32,
      "uniqueItems": true,
      "default": []
    },

    "references": {
      "type": "array",
      "description": "Optional references (tickets, docs, CVE, etc.).",
      "items": { "$ref": "#/$defs/reference" },
      "minItems": 0,
      "maxItems": 16,
      "uniqueItems": false,
      "default": []
    },

    "expected": {
      "$ref": "#/$defs/expected"
    },

    "environment": {
      "$ref": "#/$defs/environment"
    },

    "repro": {
      "$ref": "#/$defs/repro"
    }
  },

  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ticket", "doc", "cve", "url", "commit", "issue"]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },

    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "error"],
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "description": "Expected HTTP status code (or analogous code)."
        },
        "error": {
          "$ref": "#/$defs/error_contract"
        },
        "notes": {
          "type": "string",
          "minLength": 0,
          "maxLength": 2000,
          "default": ""
        }
      }
    },

    "error_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128,
          "pattern": "^[A-Z][A-Z0-9_]{1,127}$",
          "description": "Stable machine-readable error code."
        },
        "message_contains": {
          "type": "string",
          "minLength": 0,
          "maxLength": 256,
          "default": "",
          "description": "Optional substring that must be present in the error message."
        },
        "fields": {
          "type": "array",
          "description": "Optional list of fields implicated in the error.",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9_.-]+$"
          },
          "minItems": 0,
          "maxItems": 32,
          "uniqueItems": true,
          "default": []
        }
      }
    },

    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "default": ""
        },
        "base_url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "default": ""
        },
        "build": {
          "type": "string",
          "minLength": 0,
          "maxLength": 128,
          "default": ""
        }
      },
      "default": {}
    },

    "repro": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "default": "POST"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "default": "/auth"
        },
        "content_type": {
          "type": "string",
          "enum": [
            "application/json",
            "application/x-www-form-urlencoded",
            "multipart/form-data",
            "text/plain"
          ],
          "default": "application/json"
        }
      },
      "default": {}
    }
  }
}
