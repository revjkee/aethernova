# ==============================================================================
# csmarket - Industrial .gitignore
# Target stacks: Python (FastAPI), Node (React/Vite/Next), Docker, CI tooling
# ==============================================================================

# ---- Secrets / env ------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
*.keystore
*.kdb
*.ovpn
secrets/
**/secrets/
**/*.secret
**/*secret*
**/*token*
**/*apikey*
**/*api_key*
**/*credentials*
**/*password*

# ---- Python: bytecode, caches -------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
.pytype/
.pyre/
.hypothesis/
.tox/
.nox/
.cache/
pip-wheel-metadata/
*.egg-info/
.eggs/
*.egg
*.whl

# ---- Python: virtualenvs ------------------------------------------------------
.venv/
venv/
ENV/
env/
virtualenv/
.python-version

# ---- Python: build / packaging ------------------------------------------------
build/
dist/
sdist/
develop-eggs/
downloads/
lib/
lib64/
parts/
var/
wheels/
pip-log.txt

# ---- Python: coverage / test reports -----------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
junit.xml
test-results/
reports/
pytest-report.xml

# ---- Python: profiling / logs -------------------------------------------------
*.log
logs/
**/logs/
*.pid
*.seed
*.prof
*.lprof

# ---- DB / local data ----------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
data/
local-data/
tmp/
temp/
.cache-data/

# ---- Alembic ------------------------------------------------------------------
# Keep migration scripts tracked; ignore local transient artifacts only
alembic/**/__pycache__/
alembic/*.pyc

# ---- Node / Frontend ----------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnpm-store/
.eslintcache
.stylelintcache
.vite/
dist/
build/
.out/
.next/
.nuxt/
.svelte-kit/
coverage/
*.tsbuildinfo

# ---- TypeScript / tooling -----------------------------------------------------
.turbo/
.swc/
.parcel-cache/
.cache/
storybook-static/

# ---- Docker / Compose ---------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml
compose.override.yml
*.local.compose.yml

# ---- Kubernetes / Helm local output ------------------------------------------
*.rendered.yaml
*.rendered.yml
helm-charts/**/charts/
helm-charts/**/tmp/
**/.helm/

# ---- Terraform (if present) ---------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- IDEs ---------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

.idea/
*.iml
*.ipr
*.iws

# ---- OS / filesystem trash ----------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---- Editors / swap files -----------------------------------------------------
*~
*.swp
*.swo
*.tmp
*.bak
*.orig
*.rej

# ---- Jupyter (if present) -----------------------------------------------------
.ipynb_checkpoints/

# ---- Local dev services -------------------------------------------------------
redis-data/
postgres-data/
pgdata/
mongo-data/
rabbitmq-data/
minio-data/
opensearch-data/
grafana-data/
prometheus-data/

# ---- Local certificates / ACME ------------------------------------------------
certs/
**/certs/
acme/
**/acme/

# ---- Generated API clients / OpenAPI artifacts --------------------------------
openapi.json
openapi.yaml
swagger.json
swagger.yaml
generated/
**/generated/
clients/
**/clients/

# ---- Security / scans output --------------------------------------------------
.bandit
bandit-report.*
safety-report.*
trivy-report.*
grype-report.*
sarif/
**/*.sarif
**/*.sarif.json
