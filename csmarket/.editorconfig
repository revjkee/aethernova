# Top-most EditorConfig file for csmarket
# Specification: https://spec.editorconfig.org/
# Project: enforce consistent, portable, editor-agnostic baseline formatting.

root = true

# ----------------------------
# Global defaults
# ----------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 120

# ----------------------------
# Makefile must use tabs
# ----------------------------
[Makefile]
indent_style = tab

# ----------------------------
# Markdown: keep trailing spaces (used for hard line breaks)
# ----------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = 0

# ----------------------------
# Python
# ----------------------------
[*.py]
indent_size = 4
tab_width = 4
max_line_length = 120

# ----------------------------
# JavaScript / TypeScript
# ----------------------------
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2
tab_width = 2
max_line_length = 120

# ----------------------------
# JSON / YAML
# ----------------------------
[*.json]
indent_size = 2
tab_width = 2

[*.{yml,yaml}]
indent_size = 2
tab_width = 2

# ----------------------------
# TOML / INI / CFG / ENV-like
# ----------------------------
[*.toml]
indent_size = 2
tab_width = 2

[*.{ini,cfg,conf}]
indent_size = 2
tab_width = 2

[*.env]
indent_size = 2
tab_width = 2

# ----------------------------
# Shell scripts
# ----------------------------
[*.{sh,bash,zsh}]
indent_size = 2
tab_width = 2

# ----------------------------
# PowerShell
# ----------------------------
[*.{ps1,psm1,psd1}]
indent_size = 2
tab_width = 2

# ----------------------------
# Docker / Compose
# ----------------------------
[Dockerfile]
indent_size = 2
tab_width = 2

[docker-compose.yml]
indent_size = 2
tab_width = 2

[docker-compose.yaml]
indent_size = 2
tab_width = 2

# ----------------------------
# SQL
# ----------------------------
[*.sql]
indent_size = 2
tab_width = 2

# ----------------------------
# Web / styling assets
# ----------------------------
[*.{html,css,scss,sass,less}]
indent_size = 2
tab_width = 2

# ----------------------------
# Documentation / text
# ----------------------------
[*.{txt,rst}]
max_line_length = 0

# ----------------------------
# Binary / vendor-like (EditorConfig may ignore, but kept explicit)
# ----------------------------
[*.{png,jpg,jpeg,gif,webp,ico,svg,pdf,zip,gz,bz2,7z}]
charset = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
end_of_line = unset
indent_style = unset
indent_size = unset
tab_width = unset
max_line_length = unset
